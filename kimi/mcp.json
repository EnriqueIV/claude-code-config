{
  "mcpServers": {
    "engram": {
      "command": "engram",
      "args": [
        "mcp",
        "--tools=agent"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "transport": "http"
    },
    "rovo": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/mcp"
      ]
    }
  }
}